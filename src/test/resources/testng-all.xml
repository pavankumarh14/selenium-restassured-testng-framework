<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Full Regression Suite" verbose="1" parallel="tests" thread-count="3">

  <parameter name="browser" value="chrome"/>
  <parameter name="headless" value="true"/>

  <test name="API Tests">
    <classes>
      <class name="com.automation.tests.api.UserApiTest"/>
    </classes>
  </test>

  <test name="UI Tests">
    <classes>
      <class name="com.automation.tests.ui.LoginUITest"/>
    </classes>
  </test>

  <test name="Hybrid Tests">
    <classes>
      <class name="com.automation.tests.hybrid.HybridUserOrderTest"/>
    </classes>
  </test>

</suite>
